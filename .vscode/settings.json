{
    "npm.packageManager": "pnpm",
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.eslint": "explicit"
        }
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.eslint": "explicit"
        }
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.eslint": "explicit"
        }
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "editor.formatOnSaveMode": "file",
    "typescript.tsdk": "node_modules/typescript/lib",
    "[javascript][typescript][typescriptreact]": {
        "editor.codeActionsOnSave": {
            "source.fixAll.eslint": "explicit"
        }
    },
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        ".next": true,
        "node_modules": true,
        "package-lock.json": true,
        "next-env.d.ts": true,
        "postcss.config.mjs": true,
        "package.json": true,
        ".prettierrc": true,
        "app/(payload)": true,
        ".vscode": true,
        ".gitignore": true,
        "tsconfig.json": true
    },
    "hide-files.files": [
        ".next",
        "node_modules",
        "package-lock.json",
        "next-env.d.ts",
        "postcss.config.mjs",
        "package.json",
        ".prettierrc",
        "app/(payload)",
        ".vscode",
        ".gitignore",
        "tsconfig.json"
    ]
}
